<IfModule mod_rewrite.c>
  RewriteEngine On

  # Allow .well-known files (no redirects or rewrites)
  RewriteRule ^\.well-known/ - [L]

  # Allow apple-app-site-association at root
  RewriteRule ^apple-app-site-association$ - [L]

  # Force non-www (but exclude AASA)
  RewriteCond %{HTTP_HOST} ^www\.lokonomy\.in$ [NC]
  RewriteCond %{REQUEST_URI} !^/\.well-known/apple-app-site-association$
  RewriteCond %{REQUEST_URI} !^/apple-app-site-association$
  RewriteRule ^(.*)$ https://lokonomy.in/$1 [L,R=301]

  # Redirect ONLY exact homepage cleanly
  RewriteCond %{THE_REQUEST} \s/+\s [NC]
  RewriteRule ^$ /lander [L,R=302]
</IfModule>

# Set correct content type for Apple file
<Files "apple-app-site-association">
  Header set Content-Type "application/json"
</Files>
